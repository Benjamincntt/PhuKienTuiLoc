[Unit]
Description=AnTea PhuKienTuiLoc API
After=network.target

[Service]
WorkingDirectory=/var/www/publish/backend
ExecStart=/usr/bin/dotnet /var/www/publish/backend/PhuKienTuiLoc.Api.dll
Restart=always
RestartSec=5
Environment=ASPNETCORE_ENVIRONMENT=Production
Environment=ASPNETCORE_URLS=http://127.0.0.1:5280
User=www-data
Group=www-data

[Install]
WantedBy=multi-user.target
